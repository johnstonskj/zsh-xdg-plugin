# shellcheck shell=bash # -*- mode: sh; eval: (sh-set-shell "zsh") -*-
#
# @description
# 
# Return a path to the first _existing_ folder that for the package named in `$1` that
# is in one of the directories in the array `XDG_CONFIG_DIRS`.
#

builtin emulate -L zsh

typeset -gi EC_SUCCESS
typeset -gi EC_ERROR

declare package="${1}"
declare -a config_dirs
IFS=':' read -r -A config_dirs <<< "${XDG_CONFIG_DIRS}"

declare config_dir
for config_dir in "${config_dirs[@]}"; do
    if [[ -d "${config_dir}/${package}" ]]; then
        printf '%s' "${config_dir}/${package}"

        return ${EC_SUCCESS}
    fi
done

printf ''
return ${EC_ERROR}
